# Required: "devnet" or "mainnet"
ENV=devnet

# Solana RPC URL
SOLANA_RPC_URL=https://api.devnet.solana.com

# Commitment level (optional, defaults to "confirmed")
SOLANA_COMMITMENT=confirmed

# Ledger derivation path (required for env.ts / Ledger scripts)
LEDGER_DERIVATION_PATH=

# Guardian key (required for governance message creation)
GUARDIAN_KEY=
