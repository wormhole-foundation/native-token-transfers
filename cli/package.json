{
  "name": "@wormhole-foundation/ntt-cli",
  "version": "1.7.0",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write ./src",
    "test": "bun test src/ __tests__/",
    "test:e2e:evm": "bun test e2e/e2e-anvil.test.ts --timeout 600000",
    "test:e2e:solana": "bun test e2e/e2e-solana.test.ts",
    "test:e2e": "bun run test:e2e:evm && bun run test:e2e:solana"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.32"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "bin": {
    "ntt": "src/index.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "yargs": "18.0.0"
  },
  "overrides": {
    "@wormhole-foundation/sdk-base": "^5.0.0",
    "@wormhole-foundation/sdk-definitions": "^5.0.0",
    "@wormhole-foundation/sdk-evm": "^5.0.0",
    "@wormhole-foundation/sdk-evm-core": "^5.0.0",
    "@wormhole-foundation/sdk-connect": "^5.0.0",
    "@wormhole-foundation/sdk-solana": "^5.0.0",
    "@wormhole-foundation/sdk-solana-core": "^5.0.0",
    "@wormhole-foundation/sdk-sui": "^5.0.0",
    "@wormhole-foundation/sdk-sui-core": "^5.0.0"
  }
}
